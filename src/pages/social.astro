---
import Layout from '../layouts/Layout.astro';
import { socialPlatforms } from '../data/platforms.js';

const title = 'Social Media Image Resizer — Platform-Optimized Photo Cropper';
const description = 'Resize and crop images for Xiaohongshu, Douyin, WeChat, Instagram, Facebook, Twitter, YouTube, LinkedIn. Auto-optimize for each platform. All processing happens locally.';
const platformsJSON = JSON.stringify(socialPlatforms);
---
<Layout title={title} description={description} seoType="WebApplication" lang="en">
  <section class="hero">
    <h1>Social Media Image Compliance</h1>
    <p>One upload, every platform. Auto crop, compress, and watermark for all major social networks.</p>
  </section>

  <div class="tabs-wrap">
    <div class="tabs" role="tablist">
      <a href="/" class="tab-btn" role="tab">Convert</a>
      <a href="/compress" class="tab-btn" role="tab">Compress</a>
      <a href="/crop" class="tab-btn" role="tab">Crop</a>
      <a href="/watermark" class="tab-btn" role="tab">Watermark</a>
      <a href="/resize" class="tab-btn" role="tab">Resize</a>
      <a href="/social" class="tab-btn active" role="tab" aria-selected="true">Social</a>
      <a href="/web-optimizer" class="tab-btn" role="tab">Web</a>
      <a href="/ecommerce" class="tab-btn" role="tab">Ecom</a>
      <a href="/articles" class="tab-btn" role="tab">Tips</a>
    </div>
  </div>

  <div class="content">
    <article class="tool-card">
      <h2 class="sr-only">Social Media Image Resizer</h2>

      <div class="upload-area" id="uploadArea" role="button" tabindex="0">
        <svg class="upload-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="17 8 12 3 7 8"/>
          <line x1="12" y1="3" x2="12" y2="15"/>
        </svg>
        <p>Click to upload or drag & drop an image</p>
        <p class="hint">Supports JPG, PNG, WebP, GIF, BMP & more</p>
        <input type="file" id="fileInput" accept="image/*" />
      </div>
      <div id="fileInfo" class="file-info" style="display:none"></div>

      <div class="control-group">
        <label>Select Target Platform</label>
        <div class="platform-grid" id="platformGrid">
          {socialPlatforms.map(p => (
            <div class="platform-card" data-id={p.id} data-icon={p.icon} tabindex="0" role="button">
              <span class="platform-icon">{p.icon}</span>
              <span class="platform-name">{p.nameEn}</span>
              <span class="platform-size">{p.width} × {p.height}</span>
              <span class="platform-ratio">{p.ratio}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="control-group">
        <label for="socialQuality">Quality</label>
        <div class="range-row">
          <input type="range" id="socialQuality" min="10" max="100" value="80">
          <span class="range-value" id="socialQualityVal">80%</span>
        </div>
      </div>

      <div class="control-group">
        <label class="checkbox-label">
          <input type="checkbox" id="watermarkToggle">
          Add Watermark
        </label>
        <input type="text" id="watermarkText" placeholder="Your brand or @handle" style="display:none; margin-top:8px; width:100%; padding:8px 12px; border:1px solid var(--border); border-radius:8px; font-size:14px;">
      </div>

      <div class="preview-area" id="socialPreviewArea" style="display:none">
        <figure class="preview-box">
          <figcaption class="label">Original</figcaption>
          <div id="socialOrigPreview"><span class="placeholder">-</span></div>
          <div id="socialOrigSize" class="size-label"></div>
        </figure>
        <figure class="preview-box">
          <figcaption class="label" id="resultLabel">Result</figcaption>
          <div id="socialResultPreview"><span class="placeholder">Select a platform</span></div>
          <div id="socialResultSize" class="size-label"></div>
        </figure>
      </div>

      <div class="btn-group">
        <button class="btn btn-primary" id="optimizeBtn" disabled>Optimize</button>
        <button class="btn btn-secondary" id="downloadBtn" disabled>Download</button>
      </div>
    </article>
  </div>
</Layout>


<style>
  .hero { padding: 72px 24px 56px; text-align: center; max-width: var(--max-w); margin: 0 auto; }
  .hero h1 { font-size: clamp(32px, 6vw, 48px); font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; margin-bottom: 12px; }
  .hero p { font-size: clamp(15px, 2.5vw, 19px); color: var(--fg-secondary); line-height: 1.5; }
  .tabs-wrap { max-width: var(--max-w); margin: 0 auto; padding: 0 24px 24px; }
  .tabs { display: flex; gap: 2px; background: var(--bg-secondary); border-radius: var(--radius); padding: 4px; overflow: hidden; }
  .tab-btn { padding: 7px 12px; border-radius: 6px; background: transparent; color: var(--fg-secondary); font-size: 13px; font-weight: 500; text-decoration: none; transition: all .2s; white-space: nowrap; }
  .tab-btn:hover { color: var(--fg); }
  .tab-btn.active { background: var(--bg); color: var(--fg); box-shadow: 0 1px 3px rgba(0,0,0,.08); }
  .content { flex:1; max-width: var(--max-w); margin: 0 auto; padding: 0 24px 64px; width: 100%; }
  .tool-card { background: var(--bg); border:1px solid var(--border); border-radius: var(--radius); padding: 28px; }
  .sr-only { position: absolute; width:1px; height:1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border-width: 0; }
  .upload-area { border: 1.5px dashed var(--border); border-radius: var(--radius); padding: 52px 24px; text-align: center; cursor: pointer; transition: all .2s; background: var(--bg); }
  .upload-area:hover { border-color: var(--accent); background: rgba(0,113,227,.02); }
  .upload-icon { width: 44px; height: 44px; margin: 0 auto 12px; color: var(--fg-secondary); }
  .upload-area p { font-size: 15px; font-weight: 500; margin-bottom: 4px; }
  .hint { font-size: 13px; color: var(--fg-secondary); font-weight: 400 !important; }
  .file-info { font-size: 12px; color: var(--fg-secondary); padding: 8px 0; text-align: center; }
  input[type="file"] { display: none; }
  input[type="text"] { font-family: -apple-system, sans-serif; }
  .control-group { margin-bottom: 20px; }
  .control-group label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px; }
  .control-group .desc { font-size: 12px; color: var(--fg-secondary); margin-top: 4px; }
  input[type="range"] { width: 100%; accent-color: var(--accent); }
  .range-row { display: flex; align-items: center; gap: 12px; }
  .range-value { font-size: 14px; color: var(--accent); font-weight: 600; min-width: 40px; text-align: right; }
  .checkbox-label { display: inline-flex !important; align-items: center; gap: 8px; cursor: pointer; font-size: 14px !important; }
  .checkbox-label input { width: 16px; height: 16px; accent-color: var(--accent); }
  .platform-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
  .platform-card { border: 1.5px solid var(--border); border-radius: var(--radius); padding: 12px 8px; text-align: center; cursor: pointer; transition: all .2s; background: var(--bg); }
  .platform-card:hover { border-color: var(--accent); background: rgba(0,113,227,.03); }
  .platform-card.selected { border-color: var(--accent); background: rgba(0,113,227,.08); box-shadow: 0 0 0 1px var(--accent); }
  .platform-icon { display: block; font-size: 24px; margin-bottom: 4px; }
  .platform-name { display: block; font-size: 12px; font-weight: 600; color: var(--fg); }
  .platform-size { display: block; font-size: 11px; color: var(--fg-secondary); }
  .platform-ratio { display: block; font-size: 10px; color: var(--accent); font-weight: 500; }
  .preview-area { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 20px 0; }
  .preview-box { background: var(--bg-secondary); border-radius: var(--radius); padding: 16px; text-align: center; min-height: 180px; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .preview-box .label { font-size: 11px; font-weight: 600; color: var(--fg-secondary); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 10px; width: 100%; text-align: left; }
  .preview-box img { max-width: 100%; max-height: 240px; object-fit: contain; border-radius: 4px; }
  .placeholder { font-size: 13px; color: var(--fg-secondary); }
  .size-label { font-size: 12px; color: var(--fg-secondary); margin-top: 8px; }
  .size-label .saved { color: #34c759; font-weight: 600; }
  .btn { display: inline-flex; align-items: center; justify-content: center; gap: 6px; padding: 11px 22px; border-radius: 8px; font-size: 14px; font-weight: 500; border: none; cursor: pointer; transition: all .2s; font-family: -apple-system, sans-serif; }
  .btn-primary { background: var(--accent); color: #fff; }
  .btn-primary:hover { background: #0066cc; }
  .btn-primary:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn-secondary { background: var(--bg-secondary); color: var(--fg); border:1px solid var(--border); }
  .btn-group { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
  @media (max-width: 768px) {
    .platform-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .hero { padding: 48px 20px 40px; }
    .tabs-wrap { padding: 0 16px 16px; }
    .content { padding: 0 16px 48px; }
    .tool-card { padding: 20px; }
    .preview-area { grid-template-columns: 1fr; }
    .platform-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script is:inline>
  const $ = id => document.getElementById(id);
  let sourceFile = null, sourceImage = null, resultBlob = null;
  let selectedPlatform = null;

  function formatSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024*1024) return (bytes/1024).toFixed(1) + ' KB';
    return (bytes/1024/1024).toFixed(2) + ' MB';
  }

  $('socialQuality').addEventListener('input', function() {
    $('socialQualityVal').textContent = this.value + '%';
  });

  $('watermarkToggle').addEventListener('change', function() {
    $('watermarkText').style.display = this.checked ? 'block' : 'none';
  });

  // Platform selection
  document.querySelectorAll('.platform-card').forEach(card => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.platform-card').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      selectedPlatform = card.dataset.id;
      $('resultLabel').textContent = card.querySelector('.platform-name').textContent;
      if (sourceImage) {
        $('optimizeBtn').disabled = false;
        $('socialResultPreview').innerHTML = '<span class="placeholder">Click Optimize</span>';
      }
    });
  });

  // Upload
  $('uploadArea').addEventListener('click', () => $('fileInput').click());
  $('uploadArea').addEventListener('dragover', e => { e.preventDefault(); });
  $('uploadArea').addEventListener('drop', e => {
    e.preventDefault();
    if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]);
  });
  $('fileInput').addEventListener('change', () => {
    if ($('fileInput').files.length) handleFile($('fileInput').files[0]);
  });

  function handleFile(file) {
    if (!file.type.startsWith('image/')) return;
    sourceFile = file;
    const reader = new FileReader();
    reader.onload = e => {
      const img = new Image();
      img.onload = () => {
        sourceImage = img;
        $('fileInfo').textContent = file.name + ' · ' + img.naturalWidth + '×' + img.naturalHeight + ' · ' + formatSize(file.size);
        $('fileInfo').style.display = 'block';
        $('socialPreviewArea').style.display = 'grid';
        $('socialOrigPreview').innerHTML = '<img src="' + img.src + '" alt="Original">';
        $('socialOrigSize').textContent = 'Size: ' + formatSize(file.size);
        $('socialResultPreview').innerHTML = '<span class="placeholder">Select a platform</span>';
        $('socialResultSize').textContent = '';
        $('optimizeBtn').disabled = !selectedPlatform;
        $('downloadBtn').disabled = true;
      };
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);
  }

  // Optimize
  $('optimizeBtn').addEventListener('click', () => {
    if (!sourceImage || !selectedPlatform) return;
    const platform = platforms.find(p => p.id === selectedPlatform);
    if (!platform) return;

    const quality = parseInt($('socialQuality').value) / 100;
    const canvas = document.createElement('canvas');
    canvas.width = platform.width;
    canvas.height = platform.height;
    const ctx = canvas.getContext('2d');

    // Fill white background
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    // Scale to fit centered
    const scale = Math.min(canvas.width / sourceImage.naturalWidth, canvas.height / sourceImage.naturalHeight);
    const sw = sourceImage.naturalWidth * scale;
    const sh = sourceImage.naturalHeight * scale;
    const sx = (canvas.width - sw) / 2;
    const sy = (canvas.height - sh) / 2;
    ctx.drawImage(sourceImage, sx, sy, sw, sh);

    // Watermark
    if ($('watermarkToggle').checked && $('watermarkText').value) {
      ctx.globalAlpha = 0.4;
      ctx.fillStyle = '#ffffff';
      ctx.font = 'bold ' + Math.max(16, Math.floor(canvas.width * 0.04)) + 'px -apple-system, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText($('watermarkText').value, canvas.width / 2, canvas.height - 24);
      ctx.globalAlpha = 1;
    }

    canvas.toBlob(blob => {
      if (!blob) return;
      resultBlob = blob;
      const url = URL.createObjectURL(blob);
      $('socialResultPreview').innerHTML = '<img src="' + url + '" alt="Result">';
      $('socialResultSize').textContent = 'Size: ' + formatSize(blob.size);
      $('downloadBtn').disabled = false;
      $('downloadBtn').dataset.url = url;
    }, 'image/jpeg', quality);
  });

  // Download
  $('downloadBtn').addEventListener('click', () => {
    if (!$('downloadBtn').dataset.url) return;
    const a = document.createElement('a');
    a.href = $('downloadBtn').dataset.url;
    const name = sourceFile ? sourceFile.name.replace(/\.[^.]+$/, '') : 'image';
    a.download = name + '_' + selectedPlatform + '.jpg';
    a.click();
  });

  // Store platforms data for script access
  const platforms = {platformsJSON};
</script>
