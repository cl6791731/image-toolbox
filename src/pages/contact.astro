---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const title = 'Contact Us';
const description = 'Get in touch with Image Toolbox for feedback, feature requests, or business inquiries.';
---

<Layout title={title} description={description} lang="en">
  <Breadcrumb items={[{label:'Home', href:'/'}, {label:'Contact'}]} />
  <div class="ad-wrapper">
    <!-- 横向广告位 -->
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="ca-pub-4519467063111183"
         data-ad-slot="2533515795"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
  </div>


  <article class="page-content">
    <h1>Contact Us</h1>
    <p>Have feedback, feature requests, or found a bug? We'd love to hear from you.</p>

    <div class="contact-methods">
      <div class="contact-card">
        <h3>Email</h3>
        <p>ylnjs@live.com</p>
        <span class="hint">Business inquiries & feedback welcome</span>
      </div>

      <div class="contact-card">
        <h3>GitHub</h3>
        <p><a href="https://github.com/yourusername/image-toolbox" target="_blank" rel="noopener">github.com/yourusername/image-toolbox</a></p>
        <span class="hint">Open source contributions welcome</span>
      </div>
    </div>

    <h2>Frequently Asked Questions</h2>
    <div class="faq" itemscope itemtype="https://schema.org/FAQPage">
      <div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
        <h3 itemprop="name">Is Image Toolbox really free?</h3>
        <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
          <p itemprop="text">Yes, all core features are completely free. We may show non-intrusive ads to cover server costs.</p>
        </div>
      </div>

      <div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
        <h3 itemprop="name">Are my images uploaded to your server?</h3>
        <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
          <p itemprop="text">No. All processing happens locally in your browser using JavaScript. Your images never leave your device.</p>
        </div>
      </div>

      <div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
        <h3 itemprop="name">What is the maximum file size?</h3>
        <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
          <p itemprop="text">There is no fixed limit, but very large images (50MB+) may cause browser memory issues. Most modern browsers handle 10-20MB images fine.</p>
        </div>
      </div>
    </div>
  </article>
</Layout>

<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4519467063111183"
     crossorigin="anonymous"></script>
<script is:inline>
     (adsbygoogle = window.adsbygoogle || []).push({});
</script>

<style>
  .ad-wrapper {
    background: var(--bg-secondary);
    border-radius: var(--radius);
    min-height: 90px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 16px auto;
    border: 1px dashed var(--border);
    max-width: var(--max-w);
    padding: 0 24px;
  }
  .page-content { max-width: var(--max-w); margin: 0 auto; padding: 40px 24px 64px; }
  .page-content h1 { font-size: clamp(24px, 5vw, 36px); font-weight: 700; letter-spacing: -0.02em; margin-bottom: 16px; }
  .page-content p { font-size: 16px; line-height: 1.8; color: var(--fg); margin-bottom: 16px; }
  .contact-methods { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 24px 0 32px; }
  .contact-card { background: var(--bg-secondary); border-radius: var(--radius); padding: 20px; }
  .contact-card h3 { font-size: 16px; font-weight: 600; margin-bottom: 8px; }
  .contact-card p { font-size: 15px; margin-bottom: 4px; }
  .contact-card .hint { font-size: 12px; color: var(--fg-tertiary); }
  .contact-card a { color: var(--accent); text-decoration: none; }
  .contact-card a:hover { text-decoration: underline; }
  .faq { margin-top: 24px; }
  .faq-item { margin-bottom: 24px; }
  .faq-item h3 { font-size: 18px; font-weight: 600; margin-bottom: 8px; color: var(--fg); }
  .faq-item p { font-size: 15px; color: var(--fg-secondary); }
  @media (max-width: 600px) {
    .contact-methods { grid-template-columns: 1fr; }
  }
</style>
