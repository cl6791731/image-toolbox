---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { articles } from '../../data/articles-en.js';

export function getStaticPaths() {
  return articles.map(a => ({ params: { slug: a.slug }, props: a }));
}

const { slug, title, date, tags, content } = Astro.props;
const description = `Learn about ${title.toLowerCase()}. Practical image processing guide from Image Toolbox.`;
---

<Layout
  title={title}
  description={description}
  seoType="article"
  datePublished={date}
  tags={tags}
  lang="en"
>
  <Breadcrumb items={[
    {label:'Home', href:'/'},
    {label:'Tips', href:'/articles'},
    {label: title}
  ]} />

  <div class="ad-wrapper">
    <!-- 横向广告位 -->
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="ca-pub-4519467063111183"
         data-ad-slot="2533515795"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
  </div>
<article class="article-page">
    <header>
      <div class="meta">{date}</div>
      <h1>{title}</h1>
      <div class="tags">
        {tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </header>

    <div class="article-body" set:html={content} />
  </article>

</Layout>

<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4519467063111183"
     crossorigin="anonymous"></script>
<script is:inline>
     (adsbygoogle = window.adsbygoogle || []).push({});
</script>

<style>
  .ad-wrapper {
    background: var(--bg-secondary);
    border-radius: var(--radius);
    min-height: 90px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 16px auto;
    border: 1px dashed var(--border);
    max-width: var(--max-w);
    padding: 0 24px;
  }
  .article-page { max-width: var(--max-w); margin: 0 auto; padding: 40px 24px 64px; }
  .article-page header { margin-bottom: 32px; }
  .article-page .meta { font-size: 13px; color: var(--fg-tertiary); margin-bottom: 8px; }
  .article-page h1 { font-size: clamp(24px, 5vw, 36px); font-weight: 700; letter-spacing: -0.02em; line-height: 1.2; margin-bottom: 16px; }
  .article-page .tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 12px; }
  .article-page .tag { font-size: 12px; padding: 4px 12px; border-radius: 12px; background: var(--bg-secondary); color: var(--fg-secondary); font-weight: 500; }
  .article-body { font-size: 16px; line-height: 1.8; color: var(--fg); }
  .article-body p { margin-bottom: 16px; }
  .article-body ul, .article-body ol { margin-bottom: 16px; padding-left: 24px; }
  .article-body li { margin-bottom: 8px; }
  .article-body h2 { font-size: 22px; font-weight: 600; margin: 32px 0 16px; letter-spacing: -0.01em; }
  .article-body h3 { font-size: 18px; font-weight: 600; margin: 24px 0 12px; }
  .article-body strong { color: var(--fg); }
  .article-body a { color: var(--accent); text-decoration: none; }
  .article-body a:hover { text-decoration: underline; }
  .article-body pre { background: var(--bg-secondary); border-radius: var(--radius-sm); padding: 16px; overflow-x: auto; margin-bottom: 16px; font-size: 14px; line-height: 1.6; }
  .article-body code { font-size: 14px; background: var(--bg-secondary); padding: 2px 6px; border-radius: 4px; }
  .article-body pre code { background: none; padding: 0; }
  .faq-item { margin-bottom: 20px; padding: 16px; background: var(--bg-secondary); border-radius: var(--radius-sm); }
  .faq-item h3 { font-size: 16px; font-weight: 600; margin: 0 0 8px; color: var(--fg); }
  .faq-item p { font-size: 15px; color: var(--fg-secondary); margin: 0; }
</style>
