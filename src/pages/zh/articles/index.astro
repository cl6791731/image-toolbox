---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { articles } from '../../../data/articles-zh.js';

const title = '图片处理技巧与指南';
const description = '了解图片格式、压缩技巧、水印最佳实践和社交媒体图片尺寸指南。';
---

<Layout title={title} description={description} seoType="website" lang="zh">
  <Breadcrumb items={[{label:'首页', href:'/zh/'}, {label:'技巧'}]} />

  <section class="hero">
    <h1>图片处理技巧</h1>
    <p>关于格式、压缩、尺寸和最佳实践的实用指南。</p>
  </section>
<div class="content">
    <div class="article-list">
      {articles.map((article) => (
        <article class="article-card">
          <div class="meta">{article.date}</div>
          <h2><a href={`/zh/articles/${article.slug}`}>{article.title}</a></h2>
          {article.summary && <p class="summary">{article.summary}</p>}
          <div class="tags">
            {article.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</Layout>


<style>
  .hero { padding: 72px 24px 40px; text-align: center; max-width: var(--max-w); margin: 0 auto; }
  .hero h1 { font-size: clamp(32px, 6vw, 48px); font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; margin-bottom: 12px; }
  .hero p { font-size: clamp(15px, 2.5vw, 19px); color: var(--fg-secondary); line-height: 1.5; }
  .content { flex: 1; max-width: var(--max-w); margin: 0 auto; padding: 0 24px 64px; width: 100%; }
  .article-list { display: flex; flex-direction: column; gap: 12px; }
  .article-card { padding: 20px 0; border-bottom: 1px solid var(--border-light); }
  .article-card:first-child { border-top: 1px solid var(--border-light); }
  .article-card .meta { font-size: 12px; color: var(--fg-tertiary); margin-bottom: 4px; font-weight: 500; }
  .article-card h2 { font-size: 18px; font-weight: 600; margin-bottom: 8px; letter-spacing: -0.01em; line-height: 1.4; }
  .article-card h2 a { color: var(--fg); text-decoration: none; }
  .article-card h2 a:hover { color: var(--accent); }
  .article-card .summary { font-size: 14px; color: var(--fg-secondary); line-height: 1.7; margin-bottom: 8px; }
  .article-card .tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .article-card .tag { font-size: 11px; padding: 2px 10px; border-radius: 12px; background: var(--bg-secondary); color: var(--fg-secondary); font-weight: 500; }
</style>
