---
import Seo from '../components/Seo.astro';

export interface Props {
  title: string;
  description: string;
  seoImage?: string;
  seoType?: 'website' | 'article' | 'WebApplication';
  datePublished?: string;
  dateModified?: string;
  tags?: string[];
  lang?: string;
  noindex?: boolean;
}

const { 
  title, 
  description, 
  seoImage, 
  seoType, 
  datePublished, 
  dateModified, 
  tags, 
  lang = 'en',
  noindex 
} = Astro.props;

const siteTitle = lang === 'zh' ? 'Image Toolbox — 图片处理工具' : 'Image Toolbox — Free Online Image Tools';
const fullTitle = title ? `${title} | Image Toolbox` : siteTitle;
---

<!DOCTYPE html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />

  <Seo 
    title={fullTitle} 
    description={description} 
    image={seoImage}
    type={seoType}
    datePublished={datePublished}
    dateModified={dateModified}
    tags={tags}
    lang={lang}
    noindex={noindex}
  />

  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <meta name="theme-color" content="#ffffff" />

  <script is:inline src="/heic.js"></script>

<!-- Auto language detection removed to fix Google Search Console redirect issue.
       Users can manually switch language via the nav toggle.
       hreflang tags in <Seo /> component inform Google of alternate language versions. -->
  <!--
  <script is:inline>
    (function() {
      if (localStorage.getItem('lang_pref')) return;
      if (sessionStorage.getItem('lang_checked')) return;
      sessionStorage.setItem('lang_checked', '1');
      var path = location.pathname;
      var isZh = path.startsWith('/zh');
      fetch('https://ipapi.co/json/')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var isCN = data.country_code === 'CN';
          if (isCN && !isZh) {
            location.href = '/zh' + path;
          } else if (!isCN && isZh) {
            location.href = path.replace(/^\/zh/, '') || '/';
          }
        })
        .catch(function() {});
    })();
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.lang-switch a').forEach(function(a) {
        a.addEventListener('click', function() {
          localStorage.setItem('lang_pref', '1');
        });
      });
    });
  </script>
  -->

  <slot name="head" />
</head>
<body>
  <noscript>
    <div style="padding:40px;text-align:center;background:#f5f5f7;border-bottom:1px solid #d2d2d7;">
      <p style="margin:0;color:#1d1d1f;font-weight:500;">
        {lang === 'zh' 
          ? 'Image Toolbox 需要 JavaScript 才能运行。请在浏览器设置中启用 JavaScript。' 
          : 'Image Toolbox requires JavaScript to run. Please enable JavaScript in your browser settings.'}
      </p>
    </div>
  </noscript>

  <nav>
    <div class="nav-inner">
      <a href={lang === 'zh' ? '/zh/' : '/'} class="nav-logo">
        Image Toolbox <span>{lang === 'zh' ? '/ 图片处理工具' : ''}</span>
      </a>
      <div class="lang-switch">
        <a href="/zh/" class={lang === 'zh' ? 'active' : ''}>中文</a>
        <a href="/" class={lang === 'en' ? 'active' : ''}>EN</a>
      </div>
    </div>
  </nav>

  <main class="page-layout">
    <div class="main-col">
      <slot />
    </div>
  </main>

  <footer>
    <div class="footer-links">
      <a href={lang === 'zh' ? '/zh/about' : '/about'}>{lang === 'zh' ? '关于我们' : 'About'}</a>
      <a href={lang === 'zh' ? '/zh/privacy' : '/privacy'}>{lang === 'zh' ? '隐私政策' : 'Privacy'}</a>
      <a href={lang === 'zh' ? '/zh/contact' : '/contact'}>{lang === 'zh' ? '联系方式' : 'Contact'}</a>
    </div>
    <p>{lang === 'zh' ? '© 2026 Image Toolbox · 所有处理在浏览器本地完成' : '© 2026 Image Toolbox · All processing done locally in browser'}</p>
  </footer>
</body>
</html>

<style is:global>
  :root {
    --fg: #1d1d1f;
    --fg-secondary: #86868b;
    --fg-tertiary: #acacb0;
    --bg: #ffffff;
    --bg-secondary: #f5f5f7;
    --bg-tertiary: #e8e8ed;
    --accent: #0071e3;
    --accent-hover: #0077ED;
    --border: #d2d2d7;
    --border-light: #e8e8ed;
    --radius: 12px;
    --radius-sm: 8px;
    --transition: 0.2s cubic-bezier(0.25, 0.1, 0.25, 1);
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.04), 0 1px 2px rgba(0,0,0,0.02);
    --shadow-md: 0 4px 12px rgba(0,0,0,0.06), 0 2px 4px rgba(0,0,0,0.03);
    --font: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text", "Helvetica Neue", Helvetica, Arial, "Noto Sans SC", sans-serif;
    --max-w: 1024px;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--fg);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255,255,255,0.8);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--border-light);
  }
  .nav-inner {
    max-width: 1024px;
    margin: 0 auto;
    padding: 0 24px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    font-size: 17px;
    font-weight: 600;
    color: var(--fg);
    letter-spacing: -0.4px;
    text-decoration: none;
  }
  .nav-logo span { color: var(--fg-secondary); font-weight: 400; }
  .lang-switch { display: flex; gap: 2px; }
  .lang-switch a {
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 500;
    text-decoration: none;
    color: var(--fg-secondary);
    transition: var(--transition);
  }
  .lang-switch a:hover { background: var(--bg-secondary); color: var(--fg); }
  .lang-switch a.active { background: var(--fg); color: #fff; }

  .page-layout {
    display: flex;
    justify-content: center;
    flex: 1;
    gap: 0;
    padding: 0 24px;
  }
  .main-col {
    min-width: 0;
    flex: 1;
    max-width: 1060px;
    display: flex;
    flex-direction: column;
  }

  footer {
    margin-top: auto;
    padding: 32px 24px;
    text-align: center;
    font-size: 12px;
    color: var(--fg-tertiary);
    border-top: 1px solid var(--border-light);
  }
  footer a { color: var(--fg-secondary); text-decoration: none; margin: 0 10px; }
  footer a:hover { color: var(--fg); }
  .footer-links { margin-bottom: 8px; }
</style>
